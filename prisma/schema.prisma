generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  username     String         @unique
  passwordHash String
  isAdmin      Boolean        @default(false)
  createdAt    DateTime       @default(now())
  sessions     Session[]
  picks        Pick[]
  weeklyResults WeeklyResult[]
  leagueMembers LeagueMember[]
  createdLeagues League[]     @relation("CreatedBy")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Season {
  id          String       @id @default(cuid())
  name        String
  year        Int
  isActive    Boolean      @default(false)
  tournaments Tournament[]
  leagues     League[]
}

model Tournament {
  id           String            @id @default(cuid())
  seasonId     String
  name         String
  course       String
  location     String
  startDate    DateTime
  endDate      DateTime
  pickDeadline DateTime
  isComplete   Boolean           @default(false)
  externalId   String?
  season       Season            @relation(fields: [seasonId], references: [id])
  field        TournamentField[]
  results      TournamentResult[]
  picks        Pick[]
  weeklyResults WeeklyResult[]
}

model Golfer {
  id         String            @id @default(cuid())
  name       String
  ranking    Int?
  imageUrl   String?
  externalId String?
  fields     TournamentField[]
  results    TournamentResult[]
  picks      Pick[]
}

model TournamentField {
  id           String     @id @default(cuid())
  tournamentId String
  golferId     String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  golfer       Golfer     @relation(fields: [golferId], references: [id])

  @@unique([tournamentId, golferId])
}

model TournamentResult {
  id           String     @id @default(cuid())
  tournamentId String
  golferId     String
  position     Int?
  scoreToPar   Int?
  r1Score      Int?
  r2Score      Int?
  r3Score      Int?
  r4Score      Int?
  status       String     @default("active") // active, cut, wd, dq
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  golfer       Golfer     @relation(fields: [golferId], references: [id])

  @@unique([tournamentId, golferId])
}

model League {
  id        String         @id @default(cuid())
  name      String
  inviteCode String        @unique
  seasonId  String
  createdBy String
  season    Season         @relation(fields: [seasonId], references: [id])
  creator   User           @relation("CreatedBy", fields: [createdBy], references: [id])
  members   LeagueMember[]
  picks     Pick[]
  weeklyResults WeeklyResult[]
}

model LeagueMember {
  id       String   @id @default(cuid())
  leagueId String
  userId   String
  joinedAt DateTime @default(now())
  league   League   @relation(fields: [leagueId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
}

model Pick {
  id           String     @id @default(cuid())
  leagueId     String
  userId       String
  tournamentId String
  golferId     String
  pickOrder    Int
  createdAt    DateTime   @default(now())
  league       League     @relation(fields: [leagueId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  golfer       Golfer     @relation(fields: [golferId], references: [id])

  @@unique([leagueId, userId, tournamentId, golferId])
}

model WeeklyResult {
  id           String     @id @default(cuid())
  leagueId     String
  userId       String
  tournamentId String
  totalScore   Int
  rank         Int
  points       Int
  league       League     @relation(fields: [leagueId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([leagueId, userId, tournamentId])
}
